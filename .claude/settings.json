{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
